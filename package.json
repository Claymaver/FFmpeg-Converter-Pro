{
  "name": "ffmpeg-converter-pro",
  "version": "2.1.3",
  "description": "Professional FFmpeg Video Converter",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "clean": "rimraf dist node_modules package-lock.json",
    "fresh": "npm run clean && npm ci",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:win32": "electron-builder --win --ia32",
    "build:win-all": "electron-builder --win --x64 --ia32",
    "build:mac": "electron-builder --mac",
    "build:mac-universal": "electron-builder --mac --universal",
    "build:linux": "electron-builder --linux",
    "build:linux-all": "electron-builder --linux deb AppImage rpm",
    "build:all": "electron-builder --win --mac --linux",
    "dist": "npm run build:all",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^25.1.8",
    "rimraf": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.clay.ffmpeg-converter-pro",
    "productName": "FFmpeg Converter Pro",
    "copyright": "Copyright © 2026 Clay",
    "compression": "normal",
    "asar": true,
    "files": ["src/**/*", "package.json"],
    "extraFiles": [
      {
        "from": "build/",
        "to": "resources/",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": [
        {"target": "nsis", "arch": ["x64","ia32"]},
        {"target": "portable", "arch": ["x64"]}
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}",
      "signtoolOptions": {"publisherName": "Clay MacDonald"},
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FFmpeg Converter Pro",
      "license": "LICENSE",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-Portable.${ext}"
    },
    "mac": {
      "target": [
        {"target": "dmg", "arch": ["x64","arm64","universal"]},
        {"target": "zip", "arch": ["x64","arm64","universal"]}
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.video",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "This app does not use the camera",
        "NSMicrophoneUsageDescription": "This app does not use the microphone"
      }
    },
    "dmg": {
      "contents": [
        {"x": 130, "y": 220},
        {"x": 410, "y": 220, "type": "link", "path": "/Applications"}
      ],
      "title": "${productName} ${version}",
      "icon": "build/icon.icns",
      "background": "build/background.png",
      "window": {"width": 540, "height": 380}
    },
    "linux": {
      "target": [
        {"target": "AppImage", "arch": ["x64"]},
        {"target": "deb", "arch": ["x64"]},
        {"target": "rpm", "arch": ["x64"]}
      ],
      "icon": "build/icons",
      "category": "AudioVideo;Video;AudioVideoEditing",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "synopsis": "Professional FFmpeg Video Converter",
      "description": "A professional, easy-to-use video converter powered by FFmpeg with a modern interface.",
      "desktop": {
        "Name": "FFmpeg Converter Pro",
        "Comment": "Convert video files with FFmpeg",
        "GenericName": "Video Converter",
        "Keywords": "video;converter;ffmpeg;media;transcoding",
        "Categories": "AudioVideo;Video;AudioVideoEditing",
        "StartupNotify": "true"
      }
    }
  }
}